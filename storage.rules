rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Deny everything by default
    match /{allPaths=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'constitutionoflife@gmail.com' ||
        request.auth.token.email == 'grassroots@the-lfa.com.lb'
      );
    }

    // academies/{academyId}/... — academyId is the user's Firebase Auth UID
    match /academies/{academyId}/{allFiles=**} {
      allow write: if request.auth != null
                   && request.auth.uid == academyId
                   && request.resource.size <= 10 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('image/.*') ||
                     request.resource.contentType == 'application/pdf' ||
                     request.resource.contentType == 'application/msword' ||
                     request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                   );

      allow read: if request.auth != null
                  && (request.auth.uid == academyId || isAdmin());
    }
  }
}
