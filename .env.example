# Firebase Web App Configuration
# Copy this file to .env and fill in your values from Firebase Console:
# Firebase Console → Project Settings → Your Apps → Web App → Config

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional: only if you use a named Firestore database (not the default)
VITE_FIREBASE_FIRESTORE_DB_ID=

# AI Studio / Server (injected automatically by AI Studio runtime)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# SMTP for verification emails (optional — auth works without it)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
