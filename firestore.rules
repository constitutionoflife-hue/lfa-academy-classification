rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin check: hardcoded emails OR role field in the user's own document.
    // Uses request.auth.token.email (available without an extra read) for the
    // hardcoded emails, and only does a Firestore get() for role-based admins.
    function isAdmin() {
      let email = request.auth != null ? request.auth.token.email : '';
      return isSignedIn() && (
        email == 'constitutionoflife@gmail.com' ||
        email == 'grassroots@the-lfa.com.lb' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
    }

    // ── User profile documents ──────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
      allow list:   if isAdmin();

      match /progress/{key} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /adminReviews/{key} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Legacy: files stored as Firestore base64 chunks (read-only for migration)
      match /uploads/{key} {
        allow read:  if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId); // kept for any pending legacy writes
      }
    }

    // ── Academy documents (new structure) ───────────────────────────────────
    // academyId == ownerUid for simplicity (one academy per user account)
    match /academies/{academyId} {
      allow read:   if isOwner(academyId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == academyId;
      allow update: if isOwner(academyId) || isAdmin();
      allow delete: if isAdmin();
      allow list:   if isAdmin();

      // Upload metadata saved after each Firebase Storage upload
      match /uploads/{uploadId} {
        allow read:  if isOwner(academyId) || isAdmin();
        allow write: if isOwner(academyId);
      }

      // Registry entries (if migrated to sub-collection in future)
      match /registry/{profileId} {
        allow read, write: if isOwner(academyId) || isAdmin();
      }

      // Classification axis data (if migrated to sub-collection in future)
      match /classificationA/{axisId} {
        allow read, write: if isOwner(academyId) || isAdmin();
      }

      match /classificationB/{axisId} {
        allow read, write: if isOwner(academyId) || isAdmin();
      }
    }

    // ── Academy notifications (final decision alerts) ──────────────────────
    // Only admins create decision notifications; the recipient academy can
    // read their own and mark them read, but never edit the content.
    // "read" covers get/list/listen, so list queries are filtered per-document
    // against recipientUserId — one academy can never see another's notifications.
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.recipientUserId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.recipientUserId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt'])
      );
      allow delete: if isAdmin();
    }
  }
}
